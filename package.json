{
	"name": "obsidian-habits",
	"version": "0.1.0",
	"description": "Track binary, repetition, and timed habits from a carousel dashboard inside your vault.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"habits",
		"habit-tracker"
	],
	"author": "James Spratt",
	"license": "MIT",
	"dependencies": {
		"chart.js": "^4.4.0",
		"jspdf": "^2.5.2"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"@typescript-eslint/parser": "^8.0.0",
		"builtin-modules": "^4.0.0",
		"esbuild": "^0.25.0",
		"eslint": "^9.0.0",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"obsidian": "latest",
		"tslib": "^2.8.0",
		"typescript": "^5.6.0"
	}
}
